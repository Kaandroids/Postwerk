
# ============================================
# Postwerk — Environment Configuration
# Copy this file to .env and fill in values.
# Variables without defaults are REQUIRED.
# ============================================

# ── PostgreSQL ───────────────────────────────
POSTGRES_HOST=postgres               # Hostname inside Docker network
POSTGRES_PORT=5432                    # Exposed port on host
POSTGRES_DB=postwerk                  # Database name
POSTGRES_USER=postwerk                # Database user
POSTGRES_PASSWORD=changeme            # Database password (CHANGE IN PROD)

# ── Redis ────────────────────────────────────
REDIS_HOST=redis                      # Hostname inside Docker network
REDIS_PORT=6379                       # Exposed port on host
REDIS_PASSWORD=changeme               # Redis AUTH password (CHANGE IN PROD)

# ── Spring Boot ──────────────────────────────
# Active profile: dev | prod
# 'prod' is the SAFE DEFAULT for deployments (Swagger off, fail-fast on dev secrets).
# Use 'dev' ONLY for local development (re-enables Swagger UI, verbose SQL logging).
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080                      # Backend HTTP port

# ── Security & Encryption ───────────────────
# IMPORTANT: NO DEFAULTS — you MUST generate unique random values.
# Under the 'prod' profile the app FAILS TO START if these are left at the
# old shipped dev placeholders.
# JWT_SECRET must be at least 32 bytes (256 bits).  Generate with:
#   openssl rand -base64 48
# ENCRYPTION_KEY must be a base64-encoded 32-byte AES key.  Generate with:
#   openssl rand -base64 32
JWT_SECRET=
ENCRYPTION_KEY=

# ── JWT Token Expiration ─────────────────────
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000       # Access token TTL (default: 15 min)
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000   # Refresh token TTL (default: 7 days)

# ── Email Sync ───────────────────────────────
APP_SYNC_INTERVAL_MS=300000           # IMAP sync interval (default: 5 min)
APP_SYNC_INITIAL_DELAY_MS=60000       # Initial delay before first sync (default: 1 min)

# ── GDPR / Data Retention ───────────────────
GDPR_EMAIL_RETENTION_DAYS=365         # Days to keep emails before purge
GDPR_AUDIT_LOG_RETENTION_DAYS=730     # Days to keep audit logs
GDPR_ACCOUNT_DELETION_GRACE_DAYS=30   # Grace period before permanent account deletion

# ── Gemini AI ────────────────────────────────
GEMINI_API_KEY=                       # Google Gemini API key (required for AI features)
GEMINI_CHAT_MODEL=gemini-2.5-flash   # Model for AI assistant chat
GEMINI_CHAT_TEMPERATURE=0.4          # Chat response creativity (0.0–1.0)
GEMINI_CHAT_MAX_TOKENS=8192          # Max tokens per AI response

# ── CORS ─────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost  # Comma-separated allowed origins

# ── Frontend ─────────────────────────────────
FRONTEND_PORT=4200                    # Angular dev server / Nginx exposed port
API_URL=http://localhost:8080/api/v1  # Backend API base URL

# ── Integration Tests (optional) ──────────
# Real email credentials for IMAP/SMTP integration tests.
# If not set, email-related tests will use dummy data or be skipped.
TEST_IMAP_HOST=                       # e.g. imap.gmail.com
TEST_IMAP_PORT=993                    # IMAP port (default: 993)
TEST_SMTP_HOST=                       # e.g. smtp.gmail.com
TEST_SMTP_PORT=587                    # SMTP port (default: 587)
TEST_EMAIL_USER=                      # e.g. test@gmail.com
TEST_EMAIL_PASS=                      # App password or IMAP password
INTEGRATION_API_URL=http://localhost:8080  # Backend URL for integration tests
